{
  "expo": {
    "name": "Tritonia",
    "slug": "Tritonia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logos/Logo1.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logos/Logo1.png",
      "resizeMode": "contain",
      "backgroundColor": "#435816"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tritonia.customer",
      "infoPlist": {
        "UIBackgroundModes": ["fetch"]
      }
    },
    "android": {
      "package": "com.tritonia.customer",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logos/Logo1.png",
        "backgroundColor": "#435816"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["RECEIVE_BOOT_COMPLETED"]
    },
    "web": {
      "favicon": "./assets/logos/Logo1.png"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-image-picker"
    ]
  }
}
